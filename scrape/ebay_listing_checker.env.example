# Copy to `ebay_listing_checker.env` in this folder (`scrape/`). That file is gitignored.
# Put real values only in `ebay_listing_checker.env` — never paste production keys into this example file.
#
# Each variable must be a single line: KEY=value (no line breaks inside a value).
#
#   EBAY_APP_ID       — App ID (OAuth client_id for Browse API)
#   EBAY_DEV_ID       — Dev ID (Trading API smoke test; optional for Browse)
#   EBAY_CERT_ID      — Cert ID (OAuth client_secret for Browse API)
#
# Browse / Identity (optional overrides):
#   EBAY_MARKETPLACE_ID=EBAY_US
#   EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
#   EBAY_BROWSE_SLEEP_SECONDS=0.55
#
# Finding API — sold listings (sync_ebay_sales_finding_api.py):
#   EBAY_APP_ID is sent as SECURITY-APPNAME (same App Id as Browse OAuth client_id).
#   Optional: EBAY_FINDING_GLOBAL_ID=EBAY-US  (site for findCompletedItems)

EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=

EBAY_MARKETPLACE_ID=EBAY_US
EBAY_USE_SANDBOX=false
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_BROWSE_SLEEP_SECONDS=0.55

EBAY_SITE_ID=0
EBAY_COMPATIBILITY_LEVEL=1271

# RapidAPI — TCGGO Pokemon TCG API (price history, live prices). Same env file as eBay scripts.
#   RAPIDAPI_KEY — fallback X-RapidAPI-Key for https://rapidapi.com/tcggopro/api/pokemon-tcg-api
#   RAPIDAPI_KEY_TCGGO — optional dedicated TCGGO / RapidAPI key (overrides RAPIDAPI_KEY when set)
RAPIDAPI_KEY=
# RAPIDAPI_KEY_TCGGO=

# Supabase — PostgreSQL Database BaaS
SUPABASE_URL=
SUPABASE_KEY=
